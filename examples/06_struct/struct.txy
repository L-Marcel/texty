struct Address
  street, city, country: string;
endstruct;

# TODO - Valor padrão quebrado

struct User
  id: long;
  age: int;
  name, password, bio: string;
  admin: bool;
  height, weight: float;
  balance: double;
  gender: char;
  version: int;
  permission: byte;
  supervisor: option<User>;
  address: Address;
endstruct;

fn main(): int
	var user: User = new User {
    id: 0,
    age: 20,
    gender: 'm'
  };
	return 0;
endfn;